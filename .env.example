# URL base del sitio (https:// obligatorio para og:image y twitter:image)
# Usado en: SEO, Open Graph, sitemap, robots. En Vercel usa VERCEL_URL si no está definida
NEXT_PUBLIC_SITE_URL=https://propi-three.vercel.app

# URL base del API (actualmente simulada)
NEXT_PUBLIC_API_URL=https://api.propi.com/v1

# Origen del frontend (header x-frontend-source)
NEXT_PUBLIC_FRONTEND_SOURCE=web
